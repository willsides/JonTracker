# ── Garmin MapShare ─────────────────────────────────────────────────────────
# Enable MapShare in the Garmin Explore app (it's free with any inReach plan).
# Go to: Explore app → Account → MapShare → enable it and set a short identifier.
# Your share page will be: https://share.garmin.com/{MAPSHARE_ID}
MAPSHARE_ID=yourname

# How often to poll for a new location (seconds). inReach sends ~every 10 min by default.
GARMIN_POLL_INTERVAL=300

# ── Email (Gmail recommended) ────────────────────────────────────────────────
# Create a dedicated Gmail account for the tracker (e.g. jontracker2024@gmail.com).
# Then:
#   1. Enable 2-Step Verification on that account
#   2. Go to: myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → copy the 16-character password here
EMAIL_ADDRESS=jontracker2024@gmail.com
EMAIL_APP_PASSWORD=abcd efgh ijkl mnop
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_POLL_INTERVAL=60

# ── Photos ───────────────────────────────────────────────────────────────────
MAX_PHOTOS=200
SLIDESHOW_INTERVAL=8

# ── Map ──────────────────────────────────────────────────────────────────────
# Free Stadia Maps API key for Stamen Terrain tiles (shaded relief basemap).
# Sign up at: https://stadiamaps.com — no credit card required.
# Leave blank to fall back to plain OpenStreetMap tiles.
STADIA_API_KEY=

# ── External links (optional) ────────────────────────────────────────────────
# Show circular icon buttons on the map linking to Strava and/or Garmin MapShare.
# Leave blank to hide the button.
STRAVA_URL=
GARMIN_MAPSHARE_URL=https://share.garmin.com/yourname

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=change-me-to-something-random
